{
  "height": 15,
  "include": [
    "modules.jsonc"
  ],
  "layer": "top",
  "modules-center": [
    "custom/music"
  ],
  "modules-left": [
    "custom/powermenu",
    "niri/workspaces",
    "niri/window",
    "custom/polycat",
    "custom/codex-usage",
    "group/tools"
  ],
  "modules-right": [
    "tray",
    "custom/weather",
    "pulseaudio",
    "network",
    "memory",
    "battery",
    "clock"
  ],
  "position": "top",
  "reload_style_on_change": true,
}
