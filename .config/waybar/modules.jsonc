{
  "custom/powermenu": {
    "format": "пМГ",
    "tooltip": false,
    "menu": "on-click",
    "menu-file": "~/.config/waybar/power_menu.xml",
    "menu-actions": {
      "lock": "$HOME/Scripts/swaylock.sh",
      "shutdown": "shutdown",
      "reboot": "reboot",
      "suspend": "systemctl suspend",
      "hibernate": "systemctl hibernate",
    },
  },
  "niri/workspaces": {
    "format": "{icon}",
    "format-icons": {
      // Named workspaces
      // (you need to configure them in niri)
      "ghostty": "оАЗ",
      "browser": "пЙ©",
      "chat": "пЗЦ",
      "write": "пБД",
      "code": "оЬМ",
      // Icons by state
      "default": "пДС"
    }
  },
  "niri/window": {
    "format": "{app_id}",
    "rewrite": {
      "(.*) вАФ Firefox.*": "пЙ© $1",
      "(.*) - zsh": "> [$1]",
      "^com.*ghostty": "ghostty"
    },
    "max-length": 20
  },
  "custom/polycat": {
    "exec": "/usr/bin/polycat -c ~/.config/waybar/polycat-config",
    // "return-type": "json",
    "on-click": "mpv $HOME/.local/share/sounds/Meow.ogg.mp3",
    "format": "{text}",
  },
  "cava": {
    // "cava_config": "$XDG_CONFIG_HOME/cava/cava.conf",
    "framerate": 30,
    "autosens": 0,
    "sensitivity": 10,
    "bars": 14,
    "lower_cutoff_freq": 30000,
    "higher_cutoff_freq": 100000,
    "hide_on_silence": false,
    // "format_silent": "quiet",
    "method": "pulse",
    "source": "auto",
    "stereo": true,
    "reverse": false,
    "bar_delimiter": 0,
    "monstercat": false,
    "waves": false,
    "noise_reduction": 0.77,
    "input_delay": 2,
    "format-icons": [
      "вЦБ",
      "вЦВ",
      "вЦГ"
      // "вЦД",
      // "вЦЕ",
    ],
    "actions": {
      "on-click-right": "mode"
    }
  },
  "mpd": {
    "format": "пАБ  {title} {artist} {stateIcon}",
    "format-disconnected": "Disconnected пАБ",
    "format-stopped": "Stopped пАБ",
    "interval": 10,
    "state-icons": {
      "playing": "пБМ",
      "paused": "пБЛ"
    },
    "tooltip-format": "MPD (connected)",
    "tooltip-format-disconnected": "MPD (disconnected)",
    "on-click": "mpc prev",
    "on-click-right": "mpc next",
    "on-click-middle": "mpc toggle",
  },
  "tray": {
    "icon-size": 21,
    "spacing": 8,
  },
  "custom/music": {
    "format": "пАБ  {}",
    "escape": true,
    "interval": 1,
    "return-type": "json",
    "tooltip": true,
    "exec": "${HOME}/.config/waybar/scripts/music_lyrics.py --columns 32 --scroll-speed 3.2 --scroll-delay 1.2",
    "on-click": "${HOME}/.config/waybar/scripts/music_lyrics.py previous",
    "on-click-right": "${HOME}/.config/waybar/scripts/music_lyrics.py next",
    "on-click-middle": "${HOME}/.config/waybar/scripts/music_lyrics.py toggle",
    "max-length": 50
  },
  "mpris": {
    "format": "DEFAULT: {player_icon} {dynamic}",
    "format-paused": "DEFAULT: {status_icon} <i>{dynamic}</i>",
    "player-icons": {
      "default": "вЦґ",
      "mpv": "рЯОµ"
    },
    "status-icons": {
      "paused": "вПЄ"
    },
    // "ignored-players": ["firefox"]
  },
  "custom/weather": {
    "exec": "${HOME}/.config/waybar/scripts/get_weather.sh",
    "return-type": "json",
    "format": "{text}",
    "tooltip": true,
    "interval": 3600
  },
  "pulseaudio": {
    // "scroll-step": 1, // %, can be a float
    "format": "{icon} {volume}%",
    "format-muted": "ої® ",
    "format-icons": {
      "default": [
        "пА¶",
        "пАІ",
        "пА®"
      ]
    },
    "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
    "on-click-right": "pavucontrol",
  },
  "network": {
    "interface": "wlp4s0",
    "format": "{ifname}",
    "format-disconnected": "пД™",
    "format-wifi": "пЗЂ ",
    "format-alt": "пЗЂ  {essid}",
    "tooltip-format": "{signalStrength}%",
    "tooltip-format-wifi": "{essid} ({signalStrength}%)\n{ifname} : {ipaddr}",
    "tooltip-format-ethernet": "{ifname} : {ipaddr} | Click to Open GUI",
    "tooltip-format-disconnected": "Disconnected | Click to open GUI",
    "on-click-right": "nm-connection-editor",
  },
  "custom/power": {
    "tooltip": false,
    "on-click": "wlogout &",
    "format": "вПї "
  },
  "battery": {
    "interval": 30,
    "states": {
      "warning": 20,
      "critical": 10
    },
    "format": "{icon} {capacity}%",
    "format-charging": "у∞ВД {capacity}%",
    "format-plugged": "пЗ¶ {capacity}%",
    "format-alt": "{icon}",
    "format-icons": [
      "у∞ВО",
      "у∞БЇ",
      "у∞Бї",
      "у∞БЉ",
      "у∞Бљ",
      "у∞БЊ",
      "у∞Бњ",
      "у∞ВА",
      "у∞ВБ",
      "у∞ВВ",
      "у∞Бє"
    ]
  },
  "memory": {
    "internal": 30,
    "format": "пЛЫ {percentage}%",
    "format-alt": "пЛЫ swap {swapPercentage}%",
  },
  "custom/lock": {
    "tooltip": false,
    "on-click": "$HOME/Scripts/swaylock.sh &",
    "format": "пА£ ",
  },
  "clock": {
    "timezone": "Asia/Shanghai",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "format-alt": "пБ≥ {:%Y-%m-%d %a}",
    "format": "пАЧ {:%H:%M}"
  },
  //еЈ¶йФЃеЊ™зОѓеИЗжНҐжАІиГљж®°еЉП
  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Performance mode:{profile}",
    "tooltip": true,
    "format-icons": {
      "performance": "у±РЛ",
      "balanced": "ої©",
      "power-saver": "пБђ",
    },
  },
  "group/tools": {
    "orientation": "inherit",
    "transition-duration": 300,
    "drawer": {
      "transition-right-to-left": false,
    },
    "modules": [
      "idle_inhibitor",
      "custom/wfrec",
      "custom/colorpicker"
    ]
  },
  //иОЈеПЦе±ПеєХйҐЬиЙ≤colorpickerпБА
  "custom/colorpicker": {
    "tooltip": false,
    "format": "у±ПЬ",
    "on-click": "hyprpicker | wl-copy",
  },
  //wf-recorder
  "custom/wfrec": {
    "exec": "~/.config/waybar/scripts/wf-recorder.sh status-json",
    "return-type": "json",
    "format": "о≠М",
    //"interval": 1,                 // жѓПзІТеИЈжЦ∞дЄАжђ°
    "signal": 9, // дЄОиДЪжЬђйЗМзЪД WAYBAR_SIG еѓєеЇФ
    "tooltip": true,
    "on-click": "~/.config/waybar/scripts/wf-recorder.sh toggle", // еЈ¶йФЃпЉЪеЉАеІЛ/еБЬж≠Ґ
    "on-click-right": "~/.config/waybar/scripts/wf-recorder.sh stop"
  },
  //з¶Бж≠ҐзЖДе±П
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "пБЃ",
      "deactivated": "пБ∞",
    },
    "tooltip-format-activated": "idle Enabled",
    "tooltip-format-deactivated": "idle Disabled",
  },
  "custom/mako": {
    "format": "пВҐ",
    "on-click": "makoctl restore",
  },
  // и∞ГиКВеЖЕзљЃе±ПеєХдЇЃеЇ¶
  "backlight/slider": {
    "min": 5,
    "max": 100,
    "orientation": "horizontal",
  },
  "backlight": {
    "device": "amdgpu_bl1",
    "format": "{icon} {percent}%",
    "format-alt": "{icon}",
    "tooltip": false,
    "format-icons": [
      "оОН",
      "оПУ",
      "оПС",
      "оПП",
      "оПО",
      "оПН",
      "оПК",
      "оПИ",
      "оОЫ"
    ]
  },
  //и∞ГиКВе§ЦжО•е±ПеєХдЇЃеЇ¶
  "group/ddcutil": {
    "orientation": "inherit",
    "drawer": {
      "transition-left-to-right": false,
    },
    "modules": [
      "custom/ddcutil-day",
      "backlight/slider",
      "backlight",
      "custom/separator#1",
      "custom/ddcutil-sleep",
      "custom/ddcutil-night",
    ],
  },
  "custom/ddcutil-day": {
    "tooltip-format": "Ex.Monitor 100% brightness",
    "format": "у∞Г†",
    "on-click": "ddcutil --display 1 setvcp 10 100 ",
  },
  "custom/ddcutil-night": {
    "tooltip-format": "Ex.Monitor 65% brightness",
    "format": "у∞ГЯ",
    "on-click": "ddcutil --display 1 setvcp 10 65 ",
  },
  "custom/ddcutil-sleep": {
    "tooltip-format": "Ex.Monitor 5% brightness",
    "format": "у∞ГЮ",
    "on-click": "ddcutil --display 1 setvcp 10 5 ",
  },
  //еИЖйЪФзђ¶у∞ЗЭ у±Л±
  "custom/separator#1": {
    "format": "у±Л±",
    "tooltip": false,
  },
  // "custom/claude-usage": {
  //   "exec": "waybar-ai-usage claude --waybar",
  //   "format": "{}",
  //   "interval": 120,
  //   "on-click": "pkill -RTMIN+8 waybar",
  //   "return-type": "json",
  //   "signal": 8,
  //   "tooltip": true
  // },
  "custom/codex-usage": {
    "exec": "/usr/bin/codex-usage --waybar --format '{icon} {5h_pct}%-{7d_pct}%' --browser firefox",
    "return-type": "json",
    "interval": 120,
    "format": "{}",
    "tooltip": true,
    "on-click": "/usr/bin/codex-usage --waybar --format '{icon} {5h_pct}%-{7d_pct}%' --browser firefox",
    "signal": 9
  }
}
